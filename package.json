{
  "name": "transitlog-hfp-csv-sink-monitor",
  "version": "1.0.0",
  "main": "monitor.js",
  "license": "ISC",
  "scripts": {
    "start": "ts-node-dev -r dotenv/config src/index.ts",
    "build": "tsc -p .",
    "start:production": "node -r dotenv/config build/index.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@azure/storage-blob": "12.8.0",
    "@types/node": "^17.0.21",
    "@types/node-fetch": "^2.6.1",
    "@types/node-schedule": "^1.3.2",
    "date-fns": "2.28.0",
    "dotenv": "14.2.0",
    "esm": "3.2.25",
    "fs-extra": "9.1.0",
    "got": "11.5.1",
    "husky": "^1.3.1",
    "lint-staged": "^9.0.0",
    "lodash": "^4.17.21",
    "node-fetch": "2.6.1",
    "node-schedule": "2.1.0",
    "prettier": "^3.6.2",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.5.5"
  }
}
